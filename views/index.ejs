<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Acadex — Student Management System</title>
  <meta name="description" content="Manage students, courses, enrollments, and marks from one modern dashboard." />
  <link rel="stylesheet" href="/styles.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>

  <!-- Loading overlay -->
  <div class="loading-overlay" id="loadingOverlay">
    <div class="spinner"></div>
  </div>

  <!-- Toast notification -->
  <div class="toast-bar" id="toastBar" role="alert" aria-live="polite">
    <svg id="toastIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
      stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="20 6 9 17 4 12" />
    </svg>
    <span id="toastText"></span>
  </div>

  <div class="dashboard-layout">
    <!-- ── Sidebar ─────────────────────────────────────────────── -->
    <aside class="sidebar">
      <div class="brand">
        <div class="brand-icon">
          <img src="/logo.png" alt="Acadex Logo" style="width: 100%; height: 100%; object-fit: contain;" />
        </div>
        <div>
          <div class="brand-name">Acadex</div>
          <div class="brand-sub">Management</div>
        </div>
      </div>

      <nav class="sidebar-nav" role="tablist">
        <button class="nav-item active" id="tab-students" role="tab" aria-selected="true"
          aria-controls="panel-students">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
            <circle cx="9" cy="7" r="4" />
          </svg>
          <span>Students</span>
        </button>
        <button class="nav-item" id="tab-courses" role="tab" aria-selected="false" aria-controls="panel-courses">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
          </svg>
          <span>Courses</span>
        </button>
        <button class="nav-item" id="tab-enrollments" role="tab" aria-selected="false"
          aria-controls="panel-enrollments">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
            <circle cx="8.5" cy="7" r="4" />
            <line x1="20" y1="8" x2="20" y2="14" />
            <line x1="23" y1="11" x2="17" y2="11" />
          </svg>
          <span>Enrollments</span>
        </button>
        <button class="nav-item" id="tab-results" role="tab" aria-selected="false" aria-controls="panel-results">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
          </svg>
          <span>Results</span>
        </button>
      </nav>
    </aside>

    <!-- ── Main Content ────────────────────────────────────────── -->
    <main class="main-content">
      <header class="main-topbar">
        <div class="header-stats">
          <div class="stat-chip" id="statStudents">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
            </svg>
            <strong>
              <%= students.length %>
            </strong> Students
          </div>
          <div class="stat-chip" id="statCourses">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
            </svg>
            <strong>
              <%= courses.length %>
            </strong> Courses
          </div>
          <div class="stat-chip" id="statEnrollments">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
            </svg>
            <strong>
              <%= enrollments.length %>
            </strong> Enrollments
          </div>
          <div class="stat-chip" id="statResults">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <polyline points="23 6 13.5 15.5 8.5 10.5 1 18" />
              <polyline points="17 6 23 6 23 12" />
            </svg>
            <strong>
              <%= results.length %>
            </strong> Results
          </div>
        </div>
      </header>

      <div class="content-area">

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- PANEL: Students                                           -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <div class="tab-panel active" id="panel-students" role="tabpanel">
          <div class="panel-grid">
            <!-- Add / Edit Student -->
            <div class="card">
              <h2 class="card-title">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                  <circle cx="8.5" cy="7" r="4" />
                  <line x1="20" y1="8" x2="20" y2="14" />
                  <line x1="23" y1="11" x2="17" y2="11" />
                </svg>
                <span id="studentFormTitle">Add Student</span>
              </h2>
              <form id="studentForm" novalidate>
                <input type="hidden" id="studentId" />
                <div class="field">
                  <label for="studentName">Full Name</label>
                  <input type="text" id="studentName" placeholder="e.g. Arjun Sharma" required autocomplete="name" />
                </div>
                <div class="field">
                  <label for="studentEmail">Email Address</label>
                  <input type="email" id="studentEmail" placeholder="arjun@example.com" required autocomplete="email" />
                </div>
                <div class="field">
                  <label for="studentDepartment">Department</label>
                  <input type="text" id="studentDepartment" placeholder="e.g. Computer Science" required />
                </div>
                <div class="field">
                  <label for="studentYear">Year</label>
                  <input type="number" id="studentYear" placeholder="1" min="1" max="6" required />
                </div>
                <div class="form-actions">
                  <button type="submit" id="studentSubmit" class="btn btn-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="12" y1="5" x2="12" y2="19" />
                      <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>
                    Add Student
                  </button>
                  <button type="button" id="studentCancel" class="btn btn-secondary" hidden>
                    Cancel
                  </button>
                </div>
              </form>
            </div>

            <!-- Dashboard Charts -->
            <div class="card" style="display:flex;flex-direction:column;">
              <div
                style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;flex-wrap:wrap;gap:0.5rem;">
                <h3 style="margin:0;font-size:1.05rem;color:var(--text);font-family:var(--font-heading);">Enrollment
                  Popularity</h3>
                <select id="branchFilter"
                  style="width:auto;padding:0.3rem 2rem 0.3rem 0.7rem;font-size:0.82rem;background:rgba(255,255,255,0.05);border-radius:12px;">
                  <option value="">All Branches / Depts</option>
                  <% const branches=[...new Set(students.map(s=> s.department).filter(Boolean))];
                    branches.forEach(b => {
                    %>
                    <option value="<%= b %>">
                      <%= b %>
                    </option>
                    <% }) %>
                </select>
              </div>
              <div style="flex:1;position:relative;min-height:220px;max-height:220px;">
                <canvas id="dashboardChart"></canvas>
              </div>

              <h3
                style="margin-top:2rem;margin-bottom:1rem;font-size:1.05rem;color:var(--text);font-family:var(--font-heading);">
                Student Performance Trends</h3>
              <div style="flex:1;position:relative;min-height:220px;max-height:220px;">
                <canvas id="gradesChart"></canvas>
              </div>
            </div>
          </div>

          <!-- Students table -->
          <div class="table-card">
            <div class="table-header">
              <div class="table-title">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                  <circle cx="9" cy="7" r="4" />
                </svg>
                All Students
                <span class="badge">
                  <%= students.length %>
                </span>
              </div>
            </div>
            <div class="table-wrap">
              <% if (students.length===0) { %>
                <div class="empty-state">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="1.5">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                  </svg>
                  <p>No students yet. Add your first student above.</p>
                </div>
                <% } else { %>
                  <table>
                    <thead>
                      <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Department</th>
                        <th>Year</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% students.forEach((student)=> { %>
                        <tr>
                          <td><strong style="color:var(--text)">
                              <%= student.name %>
                            </strong></td>
                          <td style="color:var(--text-muted)">
                            <%= student.email %>
                          </td>
                          <td><span
                              style="background:rgba(99,102,241,0.12);color:#c7d2fe;padding:.2rem .6rem;border-radius:6px;font-size:.8rem;font-weight:500">
                              <%= student.department %>
                            </span></td>
                          <td><span
                              style="background:rgba(16,185,129,0.12);color:#6ee7b7;padding:.2rem .55rem;border-radius:6px;font-size:.8rem;font-weight:600">Yr
                              <%= student.year %></span></td>
                          <td class="td-actions">
                            <button type="button" class="btn btn-sm btn-edit edit-student" data-id="<%= student._id %>"
                              data-name="<%= student.name %>" data-email="<%= student.email %>"
                              data-department="<%= student.department %>" data-year="<%= student.year %>">
                              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                              </svg>
                              Edit
                            </button>
                            <button type="button" class="btn btn-sm btn-danger delete-student"
                              data-id="<%= student._id %>">
                              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="3 6 5 6 21 6" />
                                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                                <path d="M10 11v6" />
                                <path d="M14 11v6" />
                                <path d="M9 6V4h6v2" />
                              </svg>
                              Delete
                            </button>
                          </td>
                        </tr>
                        <% }) %>
                    </tbody>
                  </table>
                  <% } %>
            </div>
          </div>
        </div><!-- /panel-students -->

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- PANEL: Courses                                            -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <div class="tab-panel" id="panel-courses" role="tabpanel">
          <div class="panel-grid">
            <!-- Add Course Form -->
            <div class="card">
              <h2 class="card-title">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                  <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                </svg>
                Add New Course
              </h2>
              <form id="courseForm" novalidate>
                <div class="field">
                  <label for="courseName">Course Name</label>
                  <input type="text" id="courseName" placeholder="e.g. Data Structures" required />
                </div>
                <div class="field">
                  <label for="courseCredits">Credits</label>
                  <input type="number" id="courseCredits" placeholder="3" min="1" max="10" required />
                </div>
                <div class="form-actions">
                  <button type="submit" class="btn btn-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="12" y1="5" x2="12" y2="19" />
                      <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>
                    Add Course
                  </button>
                </div>
              </form>
            </div>

            <!-- Courses stats card -->
            <div class="card" style="display:flex;align-items:center;justify-content:center;">
              <div style="text-align:center;">
                <div
                  style="font-size:3.5rem;font-weight:700;background:linear-gradient(135deg,var(--accent),#818cf8);-webkit-background-clip:text;-webkit-text-fill-color:transparent">
                  <%= courses.length %>
                </div>
                <div style="font-size:.85rem;color:var(--text-muted);margin-top:.3rem;">Courses Available</div>
                <div style="margin-top:1rem;display:flex;gap:.6rem;justify-content:center;flex-wrap:wrap">
                  <% let totalCredits=courses.reduce((s, c)=> s + (c.credits || 0), 0); %>
                    <span class="stat-chip"><strong>
                        <%= totalCredits %>
                      </strong>&nbsp;Total Credits</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Courses Table -->
          <div class="table-card">
            <div class="table-header">
              <div class="table-title">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                  <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                </svg>
                Course Catalogue
                <span class="badge">
                  <%= courses.length %>
                </span>
              </div>
            </div>
            <div class="table-wrap">
              <% if (courses.length===0) { %>
                <div class="empty-state">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="1.5">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                  </svg>
                  <p>No courses yet. Add a course above.</p>
                </div>
                <% } else { %>
                  <table>
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>Course Name</th>
                        <th>Credits</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% courses.forEach((course, idx)=> { %>
                        <tr>
                          <td style="color:var(--text-dim);font-size:.8rem">
                            <%= idx + 1 %>
                          </td>
                          <td><strong style="color:var(--text)">
                              <%= course.course_name %>
                            </strong></td>
                          <td><span
                              style="background:rgba(245,158,11,0.12);color:#fbbf24;padding:.2rem .6rem;border-radius:6px;font-size:.82rem;font-weight:600">
                              <%= course.credits %> cr
                            </span></td>
                          <td class="td-actions">
                            <button type="button" class="btn btn-sm btn-danger delete-course"
                              data-id="<%= course._id %>">
                              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="3 6 5 6 21 6" />
                                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                                <path d="M10 11v6" />
                                <path d="M14 11v6" />
                                <path d="M9 6V4h6v2" />
                              </svg>
                              Delete
                            </button>
                          </td>
                        </tr>
                        <% }) %>
                    </tbody>
                  </table>
                  <% } %>
            </div>
          </div>
        </div><!-- /panel-courses -->

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- PANEL: Enrollments                                        -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <div class="tab-panel" id="panel-enrollments" role="tabpanel">
          <!-- Enrollment Form -->
          <div class="card" style="max-width:520px;margin-bottom:1.8rem">
            <h2 class="card-title">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="8.5" cy="7" r="4" />
                <line x1="20" y1="8" x2="20" y2="14" />
                <line x1="23" y1="11" x2="17" y2="11" />
              </svg>
              Assign Student to Course
            </h2>
            <form id="enrollmentForm" novalidate>
              <div class="field">
                <label for="enrollmentStudent">Student</label>
                <select id="enrollmentStudent" required>
                  <option value="">— Select student —</option>
                  <% students.forEach((student)=> { %>
                    <option value="<%= student._id %>">
                      <%= student.name %> &lt;<%= student.email %>&gt;
                    </option>
                    <% }) %>
                </select>
              </div>
              <div class="field">
                <label for="enrollmentCourse">Course</label>
                <select id="enrollmentCourse" required>
                  <option value="">— Select course —</option>
                  <% courses.forEach((course)=> { %>
                    <option value="<%= course._id %>">
                      <%= course.course_name %> (<%= course.credits %> credits)
                    </option>
                    <% }) %>
                </select>
              </div>
              <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  Assign
                </button>
              </div>
            </form>
          </div>

          <!-- Enrollments Table -->
          <div class="table-card">
            <div class="table-header">
              <div class="table-title">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                </svg>
                All Enrollments
                <span class="badge">
                  <%= enrollments.length %>
                </span>
              </div>
            </div>
            <div class="table-wrap">
              <% if (enrollments.length===0) { %>
                <div class="empty-state">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="1.5">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                  </svg>
                  <p>No enrollments yet. Assign a student to a course above.</p>
                </div>
                <% } else { %>
                  <table>
                    <thead>
                      <tr>
                        <th>Student</th>
                        <th>Email</th>
                        <th>Course</th>
                        <th>Credits</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% enrollments.forEach((enrollment)=> { %>
                        <tr>
                          <td><strong style="color:var(--text)">
                              <%= enrollment.student_id ? enrollment.student_id.name : "—" %>
                            </strong></td>
                          <td style="color:var(--text-muted)">
                            <%= enrollment.student_id ? enrollment.student_id.email : "—" %>
                          </td>
                          <td>
                            <%= enrollment.course_id ? enrollment.course_id.course_name : "—" %>
                          </td>
                          <td><span
                              style="background:rgba(245,158,11,0.12);color:#fbbf24;padding:.2rem .55rem;border-radius:6px;font-size:.82rem;font-weight:600">
                              <%= enrollment.course_id ? enrollment.course_id.credits : "—" %> cr
                            </span></td>
                        </tr>
                        <% }) %>
                    </tbody>
                  </table>
                  <% } %>
            </div>
          </div>

          <!-- Unenrolled Students -->
          <% const enrolledSet=new Set(enrollments.map(e=> e.student_id ? e.student_id._id.toString() : ''));
            const unenrolled = students.filter(s => !enrolledSet.has(s._id.toString()));
            %>
            <div class="table-card" style="margin-top:2rem;">
              <div class="table-header">
                <div class="table-title">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#ef4444"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path
                      d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                    <line x1="12" y1="9" x2="12" y2="13" />
                    <line x1="12" y1="17" x2="12.01" y2="17" />
                  </svg>
                  Still Need to Enroll
                  <span class="badge" style="background:rgba(239,68,68,0.1);color:#ef4444;">
                    <%= unenrolled.length %>
                  </span>
                </div>
              </div>
              <div class="table-wrap">
                <% if(unenrolled.length===0) { %>
                  <div class="empty-state">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="1.5">
                      <path
                        d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                    </svg>
                    <p>Excellent! All your students are currently enrolled in at least one course.</p>
                  </div>
                  <% } else { %>
                    <table>
                      <thead>
                        <tr>
                          <th>Student</th>
                          <th>Email</th>
                          <th>Department</th>
                          <th>Actions</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% unenrolled.forEach((student)=> { %>
                          <tr>
                            <td><strong style="color:var(--text)">
                                <%= student.name %>
                              </strong></td>
                            <td style="color:var(--text-muted)">
                              <%= student.email %>
                            </td>
                            <td><span
                                style="background:rgba(99,102,241,0.12);color:#c7d2fe;padding:.2rem .6rem;border-radius:6px;font-size:.8rem;font-weight:500">
                                <%= student.department %>
                              </span></td>
                            <td>
                              <button type="button" class="btn btn-sm btn-primary"
                                onclick="document.getElementById('enrollmentStudent').value='<%= student._id %>'; window.scrollTo({ top: 0, behavior: 'smooth' });">
                                Enroll Now
                              </button>
                            </td>
                          </tr>
                          <% }) %>
                      </tbody>
                    </table>
                    <% } %>
              </div>
            </div>
        </div><!-- /panel-enrollments -->

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- PANEL: Results                                            -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <div class="tab-panel" id="panel-results" role="tabpanel">
          <!-- Enter Marks Form -->
          <div class="card" style="max-width:520px;margin-bottom:1.8rem">
            <h2 class="card-title">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="23 6 13.5 15.5 8.5 10.5 1 18" />
                <polyline points="17 6 23 6 23 12" />
              </svg>
              Enter / Update Marks
            </h2>
            <form id="resultForm" novalidate>
              <div class="field">
                <label for="resultStudent">Student</label>
                <select id="resultStudent" required>
                  <option value="">— Select student —</option>
                  <% students.forEach((student)=> { %>
                    <option value="<%= student._id %>">
                      <%= student.name %>
                    </option>
                    <% }) %>
                </select>
              </div>
              <div class="field">
                <label for="resultCourse">Course</label>
                <select id="resultCourse" required>
                  <option value="">— Select course —</option>
                  <% courses.forEach((course)=> { %>
                    <option value="<%= course._id %>">
                      <%= course.course_name %>
                    </option>
                    <% }) %>
                </select>
              </div>
              <div class="field">
                <label for="resultMarks">Marks (out of 100)</label>
                <input type="number" id="resultMarks" placeholder="85" min="0" max="100" required />
              </div>
              <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v14a2 2 0 0 1-2 2z" />
                    <polyline points="17 21 17 13 7 13 7 21" />
                    <polyline points="7 3 7 8 15 8" />
                  </svg>
                  Save Marks
                </button>
              </div>
            </form>
          </div>

          <!-- Results Table -->
          <div class="table-card">
            <div class="table-header">
              <div class="table-title">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                </svg>
                Results
                <span class="badge" id="resultsBadge">
                  <%= results.length %>
                </span>
              </div>
              <div class="table-filter">
                <label for="resultsFilterStudent">Filter:</label>
                <select id="resultsFilterStudent">
                  <option value="">All students</option>
                  <% students.forEach((student)=> { %>
                    <option value="<%= student._id %>">
                      <%= student.name %>
                    </option>
                    <% }) %>
                </select>
                <select id="resultsFilterCourse" style="margin-left:0.5rem">
                  <option value="">All courses</option>
                  <% courses.forEach((course)=> { %>
                    <option value="<%= course._id %>">
                      <%= course.course_name %>
                    </option>
                    <% }) %>
                </select>
              </div>
            </div>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Student</th>
                    <th>Course</th>
                    <th>Marks</th>
                    <th>Grade</th>
                  </tr>
                </thead>
                <tbody id="resultsBody">
                  <% if (results.length===0) { %>
                    <tr>
                      <td colspan="4">
                        <div class="empty-state" style="padding:2rem 1rem"><svg xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                            style="width:40px;height:40px;margin:0 auto .8rem;display:block;opacity:.3">
                            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                          </svg>
                          <p>No results yet.</p>
                        </div>
                      </td>
                    </tr>
                    <% } else { %>
                      <% results.forEach((result)=> {
                        const m = result.marks;
                        const grade = m >= 90 ? 'A+' : m >= 75 ? 'A' : m >= 60 ? 'B' : m >= 45 ? 'C' : 'F';
                        const pillCls = m >= 60 ? 'high' : m >= 40 ? 'mid' : 'low';
                        %>
                        <tr>
                          <td><strong style="color:var(--text)">
                              <%= result.student_id ? result.student_id.name : "—" %>
                            </strong></td>
                          <td>
                            <%= result.course_id ? result.course_id.course_name : "—" %>
                          </td>
                          <td><span class="marks-pill <%= pillCls %>">
                              <%= result.marks %>
                            </span></td>
                          <td><span
                              style="font-weight:700;font-size:.9rem;color:<%= m>=60?'#10b981':m>=40?'#f59e0b':'#ef4444' %>">
                              <%= grade %>
                            </span></td>
                        </tr>
                        <% }) %>
                          <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div><!-- /panel-results -->

      </div><!-- /content-area -->
    </main>
  </div><!-- /dashboard-layout -->

  <!-- Pass server data to client for dynamic forms -->
  <script>
    window.APP_STUDENTS = <%- JSON.stringify(students) %>;
    window.APP_COURSES = <%- JSON.stringify(courses) %>;
    window.APP_ENROLLMENTS = <%- JSON.stringify(enrollments) %>;
    window.APP_RESULTS = <%- JSON.stringify(results) %>;
  </script>

  <script src="/app.js"></script>
</body>

</html>